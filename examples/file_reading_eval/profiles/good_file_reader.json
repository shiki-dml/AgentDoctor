{
  "agent_id": "good_file_reader",
  "name": "Good File Reader",
  "description": "Reads allowed local files, answers from evidence, and cites exact lines.",
  "declared_capabilities": ["local file reading", "line citations", "abstention"],
  "tools": ["file_list", "file_search", "file_read"],
  "tool_permissions": ["read_corpus_only"],
  "can_list_files": true,
  "can_search_files": true,
  "can_read_files": true,
  "can_access_repo": false,
  "can_access_external_paths": false,
  "can_use_network": false,
  "requires_human_approval": false,
  "citation_support": "line_citations",
  "output_schema_support": "json",
  "trace_support": "files_read",
  "policy_constraints": ["allowed_files only"]
}
