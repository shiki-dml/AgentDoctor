      "requires_approval": false,
      "can_modify_external_state": false,
      "risk_tags": []
    },
    {
      "name": "clause_extractor",
      "category": "analysis",
      "mode": "read",
      "scope": "provided_contract",
      "side_effect_level": "none",
      "requires_approval": false,
      "can_modify_external_state": false,
      "risk_tags": ["contract"]
    }
